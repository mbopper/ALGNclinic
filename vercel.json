{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "algnclinic.co.uk" }],
      "destination": "https://www.algnclinic.co.uk/$1",
      "permanent": true
    },
    { "source": "/index.html", "destination": "/",           "permanent": true },
    { "source": "/about.html", "destination": "/about",      "permanent": true },
    { "source": "/services.html", "destination": "/services","permanent": true },
    { "source": "/conditions.html", "destination": "/conditions", "permanent": true },
    { "source": "/locations.html", "destination": "/locations", "permanent": true },
    { "source": "/book.html",  "destination": "/book",       "permanent": true }
  ],
  "rewrites": [
    { "source": "/about",      "destination": "/about.html"      },
    { "source": "/services",   "destination": "/services.html"   },
    { "source": "/conditions", "destination": "/conditions.html" },
    { "source": "/locations",  "destination": "/locations.html"  },
    { "source": "/book",       "destination": "/book.html"       }
  ]
}
